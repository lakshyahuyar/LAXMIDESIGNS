<!DOCTYPE html>
<html>
<head>
  <title>Admin Panel</title>
  <style>
    * {
      box-sizing: border-box;
      font-family: Arial, sans-serif;
    }

    body {
      margin: 0;
      min-height: 100vh;
      background:
        linear-gradient(rgba(0,0,0,.65), rgba(0,0,0,.75)),
        url("https://images.unsplash.com/photo-1497366754035-f200968a6e72?auto=format&fit=crop&w=1600&q=80");
      background-size: cover;
      background-position: center;
      color: white;
      padding: 30px;
    }

    .dashboard {
      max-width: 1200px;
      margin: auto;
    }

    .topbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 30px;
    }

    .topbar h1 {
      margin: 0;
      font-size: 36px;
    }

    .logout {
      background: #ffcc00;
      color: #111;
      padding: 10px 18px;
      border-radius: 8px;
      text-decoration: none;
      font-weight: bold;
    }

    .cards {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 20px;
      margin-bottom: 30px;
    }

    .card {
      background: rgba(255,255,255,.14);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(255,255,255,.25);
      border-radius: 18px;
      padding: 25px;
      box-shadow: 0 15px 40px rgba(0,0,0,.25);
    }

    .card h2 {
      margin: 0;
      font-size: 38px;
      color: #ffcc00;
    }

    .card p {
      margin: 8px 0 0;
      color: #ddd;
    }

    .panel {
      background: rgba(255,255,255,.12);
      backdrop-filter: blur(16px);
      border: 1px solid rgba(255,255,255,.25);
      border-radius: 20px;
      padding: 25px;
      overflow-x: auto;
      box-shadow: 0 15px 45px rgba(0,0,0,.35);
    }

    .panel h2 {
      margin-top: 0;
      color: #ffcc00;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      min-width: 850px;
    }

    th, td {
      padding: 14px;
      text-align: left;
      border-bottom: 1px solid rgba(255,255,255,.18);
    }

    th {
      color: #ffcc00;
      font-size: 13px;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    td {
      color: #f1f1f1;
      font-size: 14px;
    }

    tr:hover {
      background: rgba(255,255,255,.08);
    }

    .empty {
      text-align: center;
      padding: 40px;
      color: #ddd;
    }

    @media (max-width: 700px) {
      body {
        padding: 15px;
      }

      .topbar {
        flex-direction: column;
        align-items: flex-start;
        gap: 15px;
      }

      .topbar h1 {
        font-size: 28px;
      }
    }
  </style>
</head>

<body>
  <div class="dashboard">

    <div class="topbar">
      <div>
        <h1>Admin Dashboard</h1>
        <p>Manage enquiries from Laxmi Printers website</p>
      </div>
      <a href="/logout" class="logout">Logout</a>
    </div>

    <div class="cards">
      <div class="card">
        <h2><%= enquiries.length %></h2>
        <p>Total Enquiries</p>
      </div>

      <div class="card">
        <h2>New</h2>
        <p>Latest website leads</p>
      </div>

      <div class="card">
        <h2>24/7</h2>
        <p>Website enquiry system</p>
      </div>
    </div>

    <div class="panel">
      <h2>Student / Customer Enquiries</h2>

      <% if (enquiries.length === 0) { %>
        <div class="empty">No enquiries yet.</div>
      <% } else { %>
        <table>
          <tr>
            <th>Name</th>
            <th>Phone</th>
            <th>Service</th>
            <th>Message</th>
            <th>Date</th>
          </tr>

          <% enquiries.forEach(e => { %>
            <tr>
              <td><%= e.name %></td>
              <td><%= e.phone %></td>
              <td><%= e.course %></td>
              <td><%= e.message %></td>
              <td><%= e.date %></td>
            </tr>
          <% }) %>
        </table>
      <% } %>
    </div>

  </div>
</body>
</html>